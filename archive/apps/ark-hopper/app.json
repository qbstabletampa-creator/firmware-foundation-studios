{
  "expo": {
    "name": "Ark Hopper",
    "slug": "ark-hopper",
    "scheme": "arkhopper",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#040A1C"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.firmwarefoundation.arkhopper",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#040A1C",
        "foregroundImage": "./assets/adaptive-icon.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/10d6557f-c3c5-4448-8a95-aff0c1ca61f0"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "10d6557f-c3c5-4448-8a95-aff0c1ca61f0"
      }
    },
    "owner": "firmfoundationstudios",
    "description": "Hop across rivers, ride logs and lily pads, and outrun the rising flood to reach Noah's Ark. A wholesome arcade hopper for kids. No ads, no tracking, no data collection."
  }
}